# Optional: strict DoR field mapping for Jira fields/custom fields.
# Example:
# DOR_FIELD_MAP_JSON={"business_goal":["field:customfield_10050"],"personas":["field:customfield_10051"],"scope":["description_section:scope"],"acceptance_criteria":["field:customfield_10052"],"dependencies":["field:customfield_10053"],"nfrs":["field:customfield_10054"],"success_metrics":["field:customfield_10055"],"rollout_plan":["field:customfield_10056"]}
DOR_FIELD_MAP_JSON=
ENABLE_TEMPLATE_HINT=true
# Optional: map canonical orchestrator states to your Jira workflow statuses.
# Example:
# ORCHESTRATOR_STATUS_MAP_JSON={"NEW":["To Do"],"TRIAGE":["In Progress"],"READY FOR REFINEMENT":["In Review"],"IN REFINEMENT":["In Progress"],"READY FOR DELIVERY":["In Review"],"IN DELIVERY":["In Progress"],"READY FOR RELEASE":["In Review"],"RELEASING":["In Progress"],"DONE":["Done"]}
ORCHESTRATOR_STATUS_MAP_JSON=
