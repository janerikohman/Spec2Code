AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=
AI_FOUNDRY_PROJECT_NAME=
AI_FOUNDRY_PROJECT_ENDPOINT=
AI_FOUNDRY_ORCHESTRATOR_AGENT_NAME=orchestrator-agent
AI_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini-agents
AI_FOUNDRY_API_VERSION=2025-05-15-preview
# Optional per-role model override map.
# Example:
# {"po-requirements":"gpt-4o-mini-agents","architect":"gpt-4o-mini-agents","security-architect":"gpt-4o-mini-agents","devops-iac":"gpt-4.1-mini-agents","developer":"gpt-4.1-mini-agents","tester-qa":"gpt-4.1-mini-agents","finops":"gpt-4.1-mini-agents","release-manager":"gpt-4o-mini-agents"}
AI_FOUNDRY_ROLE_MODEL_MAP_JSON=
AI_FOUNDRY_LOGGING_ENABLED=false
AI_FOUNDRY_OPENAPI_PROJECT_CONNECTION_ID=
# Role -> Foundry assistant id (preferred) or assistant name.
# Example:
# {"architect":"asst_...","security-architect":"asst_...","devops-iac":"asst_...","developer":"asst_...","tester-qa":"asst_...","finops":"asst_...","release-manager":"asst_..."}
AI_FOUNDRY_ROLE_AGENT_MAP_JSON=
REVIEW_FUNCTION_APP_NAME=
REVIEW_FUNCTION_STORAGE_ACCOUNT=
AZURE_KEY_VAULT_NAME=
# Skip automatic Key Vault role assignment during deploy (helps in restricted tenants).
SKIP_MI_ROLE_ASSIGNMENT=true

# Optional: strict DoR field mapping for Jira fields/custom fields.
# Example:
# DOR_FIELD_MAP_JSON={"business_goal":["field:customfield_10050"],"personas":["field:customfield_10051"],"scope":["description_section:scope"],"acceptance_criteria":["field:customfield_10052"],"dependencies":["field:customfield_10053"],"nfrs":["field:customfield_10054"],"success_metrics":["field:customfield_10055"],"rollout_plan":["field:customfield_10056"]}
DOR_FIELD_MAP_JSON=
ENABLE_TEMPLATE_HINT=true
# Optional: map canonical orchestrator states to your Jira workflow statuses.
# Example:
# ORCHESTRATOR_STATUS_MAP_JSON={"NEW":["To Do"],"TRIAGE":["In Progress"],"READY FOR REFINEMENT":["In Review"],"IN REFINEMENT":["In Progress"],"READY FOR DELIVERY":["In Review"],"IN DELIVERY":["In Progress"],"READY FOR RELEASE":["In Review"],"RELEASING":["In Progress"],"DONE":["Done"]}
ORCHESTRATOR_STATUS_MAP_JSON=
# Optional: Jira issue type for orchestrator-created agent tasks.
ORCHESTRATOR_DISPATCH_ISSUE_TYPE=Story
BITBUCKET_ENABLE_AUTOMATION=false
BITBUCKET_ENABLE_PR_AUTOMATION=false
BITBUCKET_API_BASE=https://api.bitbucket.org/2.0
BITBUCKET_REPO_SLUG=
BITBUCKET_MAIN_BRANCH=main
BITBUCKET_SINGLE_REPO_MODE=false
BITBUCKET_AUTO_CREATE_REPO=true
BITBUCKET_PROJECT_KEY=
# NOTE: BITBUCKET_WORKSPACE, BITBUCKET email/password are stored in Key Vault
# (RULE_17_BITBUCKET_SEPARATE_AUTH) — do not put them here.

# Secret names in Key Vault
# These settings tell the runtime WHAT to look up — not the values themselves.
# Create each secret in Azure Key Vault before deploying.
#
# RULE_15_SECRETS_IN_KEY_VAULT: credentials MUST be stored in Key Vault.
# RULE_16_JIRA_CONFLUENCE_SHARED_AUTH: Jira + Confluence use the same email/token.
# RULE_17_BITBUCKET_SEPARATE_AUTH: Bitbucket uses its own dedicated credentials.
#
# Required Key Vault secrets:
#   JIRA-EMAIL             — email used to authenticate Jira AND Confluence
#   JIRA-API-TOKEN         — API token used to authenticate Jira AND Confluence
#   BITBUCKET-USERNAME     — Bitbucket account username (separate from Jira)
#   BITBUCKET-APP-PASSWORD — Bitbucket app-password (separate from Jira token)
#   BITBUCKET-WORKSPACE    — Bitbucket workspace slug
#
JIRA_EMAIL_SECRET_NAME=JIRA-EMAIL
JIRA_API_TOKEN_SECRET_NAME=JIRA-API-TOKEN
BITBUCKET_USERNAME_SECRET_NAME=BITBUCKET-USERNAME
BITBUCKET_APP_PASSWORD_SECRET_NAME=BITBUCKET-APP-PASSWORD
BITBUCKET_WORKSPACE_SECRET_NAME=BITBUCKET-WORKSPACE
REVIEW_ENDPOINT_API_KEY_SECRET_NAME=REVIEW-ENDPOINT-API-KEY

# Non-secret Jira / Confluence config (URLs, project/space keys).
# Authentication credentials are in Key Vault — do not put them here.
JIRA_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=
JIRA_PROJECT_KEY=ABC
JIRA_BOARD_JQL=project = ABC AND issuetype = Epic AND statusCategory != Done ORDER BY created ASC

REVIEW_ENDPOINT_BASE_URL=
